model Insurance {
    id            String                @id @default(uuid())
    bankName      BankName
    amount        String?
    coverImage    String?
    periodMonths  String?
    processingFee String
    interestRate  String
    monthlyEmi    String?
    totalAmount   String?
    eligibleLoan  String?
    insuranceType InsuranceType
    isActive      Boolean               @default(false)
    createdAt     DateTime              @default(now())
    updatedAt     DateTime              @updatedAt
    userId        String?
    user          User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    eligibility   EligibilityInsurance?
    feesCharges   FeesChargesInsurance?
    features      FeaturesInsurance?

    @@map("insurances")
}


model FeaturesInsurance {
    id            String    @id @default(uuid())
    loanAmount    String
    minimumAmount String
    maximumAmount String
    loanTenure    String
    minimumYear   String
    maximumYear   String
    insuranceId   String    @unique
    insurance     Insurance @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
}

model EligibilityInsurance {
    id                String    @id @default(uuid())
    condition         String
    offer             String
    minimumIncome     Int
    minimumExperience Int
    ageRequirement    Int
    insuranceId       String    @unique
    insurance         Insurance @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
}

model FeesChargesInsurance {
    id                  String    @id @default(uuid())
    processingFee       String
    earlySettlementFee  String
    prepaymentFee       String
    LoanReSchedulingFee String
    penalCharge         String
    insuranceId         String    @unique
    insurance           Insurance @relation(fields: [insuranceId], references: [id], onDelete: Cascade)
}

enum InsuranceType {
    CAR_INSRUNCE               
    BIKE_INSRUNCE
} 
